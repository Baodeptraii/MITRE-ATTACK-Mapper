  "T1059.001": {
    "tactic": "execution",
    "name": "Command and Scripting Interpreter: PowerShell",
    "rules": {
      "Suricata": [],
      "Sysmon": [
        {
          "name": "PowerShell Network Connection",
          "event_id": 3,
          "query": "EventID=3 AND Image='*\\powershell.exe'",
          "confidence": "Medium",
          "reference": "https://www.ultimatewindowssecurity.com/securitylog/encyclopedia/event.aspx?eventid=90003"
        },
        {
          "name": "Suspicious PowerShell CommandLine",
          "event_id": 1,
          "query": "EventID=1 AND Image='*\\powershell.exe' AND (CommandLine contains '-enc' OR CommandLine contains '-nop')",
          "confidence": "High",
          "reference": ""
        }
      ],
      "Wazuh": [
        {
          "name": "PowerShell Script Block Logging",
          "rule_id": 100002,
          "query": "<rule id=\"100002\" level=\"12\">\n  <if_sid>60103</if_sid>\n  <field name=\"win.eventdata.scriptBlockText\">Invoke-Mimikatz|DownloadString</field>\n</rule>",
          "confidence": "High",
          "reference": "https://wazuh.com/"
        }
      ],
      "Windows Event Log": [
        {
          "name": "PowerShell Script Block Logging (4104)",
          "event_id": 4104,
          "query": "EventID=4104 AND ScriptBlockText contains suspicious patterns",
          "confidence": "High",
          "reference": ""
        }
      ],
      "Sigma": [
        {
          "name": "Suspicious PowerShell Execution",
          "query": "EventID=1 AND (CommandLine contains '-enc' OR CommandLine contains 'DownloadString')",
          "confidence": "High",
          "reference": "https://github.com/SigmaHQ/sigma/blob/master/rules/windows/process_creation/proc_creation_win_powershell_suspicious_parameter.yml"
