  "T1566.001": {
    "tactic": "initial-access",
    "name": "Phishing: Spearphishing Attachment",
    "rules": {
      "Suricata": [
        {
          "name": "Suspicious Office Document Download",
          "sid": 1000001,
          "query": "alert http $EXTERNAL_NET any -> $HOME_NET any (msg:\"Suspicious Office File Download\"; fileext:\"docm\"; sid:1000001;)",
          "confidence": "Medium",
          "reference": "https://rules.emergingthreats.net/"
        }
      ],
      "Sysmon": [
        {
          "name": "Office Application Spawning Shell",
          "event_id": 1,
          "query": "EventID=1 AND ParentImage='*\\OUTLOOK.EXE' AND (Image='*\\cmd.exe' OR Image='*\\powershell.exe')",
          "confidence": "High",
          "reference": "https://github.com/SigmaHQ/sigma/blob/master/rules/windows/process_creation/proc_creation_win_office_shell.yml"
        }
      ],
      "Wazuh": [
        {
          "name": "Office Macro Execution Alert",
          "rule_id": 100010,
          "query": "<rule id=\"100010\" level=\"12\">\n  <if_sid>60103</if_sid>\n  <field name=\"win.eventdata.ParentImage\">OUTLOOK.EXE</field>\n  <field name=\"win.eventdata.Image\">cmd.exe|powershell.exe</field>\n</rule>",
          "confidence": "High",
          "reference": "https://wazuh.com/"
        }
      ],
      "Windows Event Log": [],
      "Sigma": [
        {
          "name": "Spearphishing Attachment Execution",
          "query": "EventID=1 AND ParentImage='*\\OUTLOOK.EXE' AND Image='*\\cmd.exe' OR Image='*\\powershell.exe'",
          "confidence": "High",
          "reference": "https://github.com/SigmaHQ/sigma/blob/master/rules/windows/process_creation/proc_creation_win_office_shell.yml"
        }
      ]
    }
  },
